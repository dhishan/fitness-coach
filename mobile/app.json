{
  "expo": {
    "name": "Fitness Tracker",
    "slug": "fitness-tracker",
    "version": "1.0.59",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "fitness",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.blueelephants.fitnesstracker",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Read steps, weight, workouts, HRV, and sleep from Apple Health to track your training.",
        "NSHealthUpdateUsageDescription": "We do not write to Apple Health.",
        "NSCameraUsageDescription": "Scan barcodes to log packaged foods.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.610355955735-o419lsj7882jl3dqfn02nm1kmmm21vf6"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3B82F6"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-image",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Scan barcodes to log packaged foods.",
          "microphonePermission": false,
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Fitness Tracker to access your photos to log meals.",
          "cameraPermission": "Allow Fitness Tracker to access your camera to log meals."
        }
      ],
      [
        "react-native-health",
        {
          "isClinicalDataEnabled": false,
          "healthSharePermission": "Read steps, weight, workouts, HRV, and sleep from Apple Health to track your training.",
          "healthUpdatePermission": "We do not write to Apple Health."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4",
            "useFrameworks": "static"
          }
        }
      ],
      "@react-native-google-signin/google-signin",
      "@react-native-community/datetimepicker",
      [
        "@sentry/react-native/expo",
        {
          "organization": "dhishan",
          "project": "fitness-tracker-mobile",
          "url": "https://sentry.io/"
        }
      ]
    ],
    "extra": {
      "sentry": {
        "dsn": "https://f16f8b5b8995e20c6a40887f8098264f@o4511581462921216.ingest.us.sentry.io/4511583731253248"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
